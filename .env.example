# Telegram MTProto credentials
# Get at https://my.telegram.org → API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Phone number for the userbot (with country code, e.g. +79001234567)
TELEGRAM_PHONE=

# Telegram Bot Token
# Get from @BotFather → /newbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_2FA_PASSWORD=
# Anthropic API key
# Get at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Path to SQLite database file
DB_PATH=./data.db