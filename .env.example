# Telegram MTProto credentials
# Get at https://my.telegram.org → API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Phone number for the userbot (with country code, e.g. +79001234567)
TELEGRAM_PHONE=
TELEGRAM_2FA_PASSWORD=

# Telegram Bot Token
# Get from @BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# LLM API key
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Path to SQLite database file and prompt
DB_PATH=./data.db
DIGEST_PROMPT_PATH=

# Maximum digest size in characters (depends on your LLM provider limits)
# For free Groq tier (12K TPM) 20000 is recommended
MAX_DIGEST_CHARS=20000